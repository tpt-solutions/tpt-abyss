# Generated by Cargo
/target/
**/target/

# Cargo lock is committed for the workspace binary; keep it.
# (Do not ignore Cargo.lock)

# Backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these
*.pdb

# Model files (GGUF weights are large; do not commit)
*.gguf
/models/
/.cache/

# Editor / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Benchmark / profiling artifacts
/criterion/
flamegraph.svg
perf.data*
